# Sepatifay Environment Variables Example

# The URL of your Next.js application
NEXTAUTH_URL="http://localhost:3000"

# Generate a secret key by running this in your terminal:
# openssl rand -base64 32
NEXTAUTH_SECRET="your_generated_secret_here"

# Admin credentials for the Admin Panel (HTTP Basic Auth)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="secure_admin_password_here"

# S3 Configuration
S3_ENDPOINT="https://c975767.parspack.net"
S3_ACCESS_KEY_ID="your_access_key_here"
S3_SECRET_ACCESS_KEY="your_secret_key_here"
S3_BUCKET_NAME="your_bucket_name_here"
